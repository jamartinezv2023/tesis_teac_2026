# PDFs generados localmente
# (si desea versionar el PDF final, comente esta línea)
# =========================================================

*.pdf

# =========================================================
# Archivos auxiliares dentro de subcarpetas
# =========================================================

chapters/*.aux
frontmatter/*.aux
appendices/*.aux
annexes/*.aux

